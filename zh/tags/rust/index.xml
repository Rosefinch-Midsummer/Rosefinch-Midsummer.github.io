    <item>
      <title>在Windows11上安装rust教程</title>
      <link>https://rosefinch-midsummer.github.io/zh/posts/tech/%E5%9C%A8windows11%E4%B8%8A%E5%AE%89%E8%A3%85rust%E6%95%99%E7%A8%8B/</link>
