    <item>
      <title>《牧羊少年奇幻之旅》</title>
      <link>https://rosefinch-midsummer.github.io/zh/posts/read/%E7%89%A7%E7%BE%8A%E5%B0%91%E5%B9%B4%E5%A5%87%E5%B9%BB%E4%B9%8B%E6%97%85/</link>
