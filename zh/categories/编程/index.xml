    <item>
      <title>Python实现文章下载器</title>
      <link>https://rosefinch-midsummer.github.io/zh/posts/tech/python%E5%AE%9E%E7%8E%B0%E6%96%87%E7%AB%A0%E4%B8%8B%E8%BD%BD%E5%99%A8/</link>
